{
  "expo": {
    "name": "Paintpile",
    "slug": "paintpile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "paintpile",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.paintpile.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload photos of your miniatures",
        "NSCameraUsageDescription": "Take photos of your miniatures"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0e14"
      },
      "package": "com.paintpile.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload photos of your miniatures"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
