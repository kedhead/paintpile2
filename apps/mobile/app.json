{
  "expo": {
    "name": "PaintPile",
    "slug": "paintpile",
    "owner": "paintpile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "paintpile",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#140A18"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paintpile.app",
      "buildNumber": "1",
      "associatedDomains": ["applinks:thepaintpile.com"],
      "infoPlist": {
        "NSCameraUsageDescription": "PaintPile needs camera access so you can take photos of your miniatures and hobby projects.",
        "NSPhotoLibraryUsageDescription": "PaintPile needs photo library access so you can share images of your miniatures.",
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock PaintPile."
      },
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#140A18",
        "dark": {
          "image": "./assets/splash.png",
          "backgroundColor": "#140A18"
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#140A18"
      },
      "package": "com.paintpile.app",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "thepaintpile.com",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FA4FD1"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow PaintPile to use Face ID to unlock the app."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "9ac56be0-216d-4b1a-a6e9-29bbf33b287b"
      },
      "pocketbaseUrl": "https://thepaintpile.com",
      "router": {
        "origin": false
      }
    }
  }
}
