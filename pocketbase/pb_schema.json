[
  {
    "name": "users",
    "type": "auth",
    "schema": [
      { "name": "name", "type": "text", "required": true },
      { "name": "username", "type": "text", "options": { "min": 3, "max": 20, "pattern": "^[a-z0-9_]+$" } },
      { "name": "bio", "type": "text", "options": { "max": 200 } },
      { "name": "avatar", "type": "file", "options": { "maxSelect": 1, "maxSize": 5242880, "mimeTypes": ["image/jpeg", "image/png", "image/webp"] } },
      { "name": "settings", "type": "json" },
      { "name": "last_active_at", "type": "date" }
    ],
    "options": {
      "allowEmailAuth": true,
      "allowOAuth2Auth": true,
      "allowUsernameAuth": false,
      "minPasswordLength": 6
    },
    "listRule": "",
    "viewRule": "",
    "createRule": "",
    "updateRule": "@request.auth.id = id",
    "deleteRule": "@request.auth.id = id"
  },
  {
    "name": "user_stats",
    "type": "base",
    "schema": [
      { "name": "user", "type": "relation", "required": true, "options": { "collectionId": "users", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "project_count", "type": "number", "options": { "min": 0 } },
      { "name": "photo_count", "type": "number", "options": { "min": 0 } },
      { "name": "pile_count", "type": "number", "options": { "min": 0 } },
      { "name": "paint_count", "type": "number", "options": { "min": 0 } },
      { "name": "follower_count", "type": "number", "options": { "min": 0 } },
      { "name": "following_count", "type": "number", "options": { "min": 0 } },
      { "name": "army_count", "type": "number", "options": { "min": 0 } },
      { "name": "likes_received", "type": "number", "options": { "min": 0 } },
      { "name": "recipes_created", "type": "number", "options": { "min": 0 } },
      { "name": "badge_count", "type": "number", "options": { "min": 0 } },
      { "name": "comment_count", "type": "number", "options": { "min": 0 } },
      { "name": "post_count", "type": "number", "options": { "min": 0 } }
    ],
    "listRule": "",
    "viewRule": "",
    "createRule": "@request.auth.id != ''",
    "updateRule": "@request.auth.id = user",
    "deleteRule": null
  },
  {
    "name": "follows",
    "type": "base",
    "schema": [
      { "name": "follower", "type": "relation", "required": true, "options": { "collectionId": "users", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "following", "type": "relation", "required": true, "options": { "collectionId": "users", "cascadeDelete": true, "maxSelect": 1 } }
    ],
    "indexes": [],
    "listRule": "",
    "viewRule": "",
    "createRule": "@request.auth.id = follower && follower != following",
    "updateRule": null,
    "deleteRule": "@request.auth.id = follower"
  },
  {
    "name": "posts",
    "type": "base",
    "schema": [
      { "name": "user", "type": "relation", "required": true, "options": { "collectionId": "users", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "content", "type": "text", "required": true, "options": { "max": 2000 } },
      { "name": "tags", "type": "json" },
      { "name": "images", "type": "file", "options": { "maxSelect": 10, "maxSize": 10485760, "mimeTypes": ["image/jpeg", "image/png", "image/webp", "image/gif"] } },
      { "name": "videos", "type": "file", "options": { "maxSelect": 3, "maxSize": 52428800, "mimeTypes": ["video/mp4", "video/webm", "video/quicktime"] } },
      { "name": "text_overlays", "type": "json" },
